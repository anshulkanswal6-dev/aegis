# AEGIS Backend Configuration
# ----------------------------

# --- GenAI Models ---
# gemini_flash (recommended), gemini_pro
DEFAULT_PLANNING_MODEL=gemini_flash
DEFAULT_CODEGEN_MODEL=gemini_flash

# --- AI Studio API Key ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Persistence Backend ---
# Options: supabase, json_file
STORE_BACKEND=json_file

# --- Supabase Admin configuration (Use SECRET Service Role Key) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here

# --- Telegram Bot Configuration ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=Aegis_telebot
TELEGRAM_WEBHOOK_URL=https://your-public-url.com/api/telegram/webhook

# --- Monad Testnet / Blockchain ---
RPC_URL=https://testnet-rpc.monad.xyz
EXPLORER_URL=https://testnet.monadexplorer.com
CHAIN_ID=10143

# --- Executor (Backend Node Identity) ---
# Used for executing on-chain actions
EXECUTOR_PRIVATE_KEY=your_private_key_here

# --- CORS ---
# Local: http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173
